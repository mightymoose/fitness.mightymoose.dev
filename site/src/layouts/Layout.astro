---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #0c0c0e;
        --surface: #1a1a1e;
        --surface-hover: #222226;
        --border: rgba(232, 224, 212, 0.08);
        --border-strong: rgba(232, 224, 212, 0.14);
        --text: #e8e0d4;
        --text-secondary: #a89f93;
        --text-muted: #6d665d;
        --accent: #c47d3c;
        --accent-glow: rgba(196, 125, 60, 0.15);
        --accent-light: #d4944f;
        --green: #7dab6e;
        --green-bg: rgba(125, 171, 110, 0.1);
        --yellow: #c9a84c;
        --yellow-bg: rgba(201, 168, 76, 0.1);
        --red: #c75b5b;
        --red-bg: rgba(199, 91, 91, 0.1);
        --blue: #6b9fc7;
        --blue-bg: rgba(107, 159, 199, 0.1);
        --font-display: 'DM Serif Display', Georgia, serif;
        --font-body: 'DM Sans', -apple-system, sans-serif;
        --font-mono: 'JetBrains Mono', 'SF Mono', monospace;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; }

      /* ─── Titlebar ─── */
      .titlebar {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        max-width: 880px;
        margin: 0 auto;
        padding: 0.75rem 2rem;
      }

      .titlebar-brand {
        font-family: var(--font-display);
        font-size: 1rem;
        color: var(--text);
        text-decoration: none;
        margin-right: auto;
      }

      .titlebar a:not(.titlebar-brand) {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.15s;
      }

      .titlebar a:not(.titlebar-brand):hover,
      .titlebar a:not(.titlebar-brand).active {
        color: var(--text);
      }

      .titlebar-sep {
        width: 100%;
        max-width: 880px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .titlebar-sep::after {
        content: '';
        display: block;
        border-bottom: 1px solid var(--border);
      }

      /* ─── Page ─── */
      .page {
        max-width: 880px;
        margin: 0 auto;
        padding: 0 2rem 3rem;
      }

      /* ─── Page Header (compact) ─── */
      .page-header {
        padding: 1.5rem 0 1rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
      }

      .page-header h1 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 400;
        color: var(--text);
        line-height: 1.2;
      }

      .page-header .subtitle {
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin-top: 0.2rem;
      }

      /* ─── Breadcrumb ─── */
      .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding-top: 1rem;
        margin-bottom: -0.5rem;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.05em;
        color: var(--text-muted);
      }

      .breadcrumb a {
        color: var(--text-muted);
        text-decoration: none;
      }

      .breadcrumb a:hover { color: var(--accent); }

      /* ─── Section Headers ─── */
      .section { margin-bottom: 2.5rem; }

      .section-header {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }

      .section-header h2 {
        font-family: var(--font-display);
        font-size: 1.2rem;
        font-weight: 400;
        color: var(--text);
      }

      .section-header .count {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--text-muted);
      }

      /* ─── Cards ─── */
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.25rem;
        margin-bottom: 0.75rem;
        transition: border-color 0.15s;
      }

      .card:hover { border-color: var(--border-strong); }

      /* ─── Badges ─── */
      .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        line-height: 1;
      }

      .badge-strength { background: rgba(196,125,60,0.12); color: var(--accent-light); border: 1px solid rgba(196,125,60,0.2); }
      .badge-volume { background: var(--green-bg); color: var(--green); border: 1px solid rgba(125,171,110,0.2); }
      .badge-technique { background: var(--blue-bg); color: var(--blue); border: 1px solid rgba(107,159,199,0.2); }
      .badge-speed { background: var(--yellow-bg); color: var(--yellow); border: 1px solid rgba(201,168,76,0.2); }
      .badge-warmup { background: rgba(255,255,255,0.03); color: var(--text-muted); border: 1px solid var(--border); }
      .badge-work { background: rgba(232,224,212,0.06); color: var(--text-secondary); border: 1px solid var(--border); }
      .badge-backoff { background: var(--yellow-bg); color: var(--yellow); border: 1px solid rgba(201,168,76,0.2); }
      .badge-dropset { background: var(--red-bg); color: var(--red); border: 1px solid rgba(199,91,91,0.2); }
      .badge-program { background: var(--accent-glow); color: var(--accent-light); border: 1px solid rgba(196,125,60,0.25); }

      /* ─── Tables ─── */
      table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }

      th {
        text-align: left;
        padding: 0.5rem 0.65rem;
        border-bottom: 1px solid var(--border-strong);
        color: var(--text-muted);
        font-family: var(--font-mono);
        font-weight: 500;
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      td {
        padding: 0.4rem 0.65rem;
        border-bottom: 1px solid var(--border);
        font-variant-numeric: tabular-nums;
      }

      tr:last-child td { border-bottom: none; }

      .num { font-family: var(--font-mono); font-size: 0.8rem; }
      .weight { font-family: var(--font-mono); font-weight: 500; color: var(--text); }
      .weight-unit { color: var(--text-muted); font-size: 0.7rem; margin-left: 0.1em; }

      /* ─── RPE ─── */
      .rpe { display: inline-flex; align-items: center; gap: 0.35rem; }
      .rpe-value { font-family: var(--font-mono); font-weight: 500; font-size: 0.8rem; }
      .rpe-bar { display: inline-flex; gap: 2px; }
      .rpe-dot { width: 3px; height: 10px; border-radius: 1.5px; background: var(--border-strong); }
      .rpe-dot.filled { background: currentColor; }
      .rpe-easy { color: var(--green); }
      .rpe-moderate { color: var(--yellow); }
      .rpe-hard { color: var(--red); }

      /* ─── Exercise Block (within workout) ─── */
      .exercise-block { padding-top: 1rem; margin-top: 1rem; border-top: 1px solid var(--border); }
      .exercise-block:first-of-type { padding-top: 0; margin-top: 0.5rem; border-top: none; }

      .exercise-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.3rem; flex-wrap: wrap; }
      .exercise-name { font-size: 0.95rem; font-weight: 600; color: var(--text); }
      .implement-tag { font-family: var(--font-mono); font-size: 0.55rem; color: var(--text-muted); letter-spacing: 0.06em; text-transform: uppercase; }
      .strategy-note { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 0.5rem; padding-left: 0.65rem; border-left: 2px solid var(--border-strong); }

      /* ─── Workout Card Header ─── */
      .workout-header { display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem; flex-wrap: wrap; }
      .workout-date { font-family: var(--font-display); font-size: 1.1rem; color: var(--text); }
      .workout-goal { font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.1rem; }

      /* ─── Stats Row ─── */
      .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0.75rem; margin-bottom: 2rem; }
      .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 0.75rem 1rem; }
      .stat-value { font-family: var(--font-mono); font-size: 1.5rem; font-weight: 500; color: var(--text); line-height: 1.1; }
      .stat-label { font-family: var(--font-mono); font-size: 0.5rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-top: 0.15rem; }

      /* ─── Exercise Grid (dashboard) ─── */
      .exercise-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 0.75rem; }

      .exercise-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1rem;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.15s, transform 0.1s;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .exercise-card:hover { border-color: var(--accent); transform: translateY(-1px); }
      .exercise-card-name { font-family: var(--font-display); font-size: 1rem; color: var(--text); }
      .exercise-card-stats { display: flex; gap: 1.25rem; }
      .exercise-card-stat { display: flex; flex-direction: column; }
      .exercise-card-stat-value { font-family: var(--font-mono); font-size: 0.9rem; font-weight: 500; color: var(--text); }
      .exercise-card-stat-label { font-family: var(--font-mono); font-size: 0.5rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }
      .exercise-card-footer { display: flex; align-items: center; gap: 0.4rem; }

      .velocity-indicator {
        display: inline-flex; align-items: center; gap: 0.2rem;
        font-family: var(--font-mono); font-size: 0.55rem; color: var(--accent-light);
        letter-spacing: 0.05em; text-transform: uppercase;
      }
      .velocity-indicator::before { content: ''; display: inline-block; width: 5px; height: 5px; border-radius: 50%; background: var(--accent); }

      /* ─── Workout List (workouts page) ─── */
      .workout-list-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.85rem 1.1rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        margin-bottom: 0.5rem;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.15s;
      }

      .workout-list-item:hover { border-color: var(--accent); }
      .workout-list-date { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text); min-width: 7rem; }
      .workout-list-goal { font-size: 0.85rem; color: var(--text-secondary); flex: 1; }
      .workout-list-meta { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); }

      /* ─── Chart Card ─── */
      .chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 0.75rem; margin-bottom: 0.75rem; overflow: hidden; }
      .chart-card svg { display: block; width: 100%; height: auto; }

      /* ─── Misc ─── */
      .row-incomplete { opacity: 0.3; }

      footer {
        margin-top: 3rem; padding: 1.5rem 0; border-top: 1px solid var(--border);
        text-align: center; color: var(--text-muted); font-size: 0.65rem;
        font-family: var(--font-mono); letter-spacing: 0.05em;
      }

      @media (max-width: 640px) {
        .page { padding: 0 1rem 2rem; }
        .titlebar { padding: 0.75rem 1rem; }
        .titlebar-sep { padding: 0 1rem; }
        table { font-size: 0.75rem; }
        th, td { padding: 0.35rem 0.4rem; }
        .workout-list-item { flex-wrap: wrap; gap: 0.4rem; }
      }
    </style>
  </head>
  <body>
    <div class="titlebar">
      <a href="/" class="titlebar-brand">Mighty Moose</a>
      <a href="/">Dashboard</a>
      <a href="/workouts">Workouts</a>
      <a href="/progress">Progress</a>
      <a href="/prs">PRs</a>
      <a href="/body-comp">Body</a>
    </div>
    <div class="titlebar-sep"></div>
    <div class="page">
      <slot />
      <footer>Powered by velocity-based training data</footer>
    </div>
  </body>
</html>
