---
import Layout from '../layouts/Layout.astro';
import {
  getWeeklyVolume,
  getIntentDistribution,
  getVolumeByExercise,
  getTotalStats,
  slugify,
} from '../lib/db';

const weeklyVolume = getWeeklyVolume();
const intentDist = getIntentDistribution();
const volumeByExercise = getVolumeByExercise();
const stats = getTotalStats();

const totalIntentSets = intentDist.reduce((s, i) => s + i.count, 0);

function fmtVol(v: number) { return v >= 1000 ? (v / 1000).toFixed(1) + 'k' : v.toString(); }
function pct(n: number, total: number) { return total > 0 ? Math.round(n / total * 100) : 0; }
---

<Layout title="Progress — Mighty Moose Fitness">
  <div class="page-header">
    <h1>Progress & Analytics</h1>
    <p class="subtitle">Patterns, not just raw data</p>
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-value">{stats.workouts}</div>
      <div class="stat-label">Total Sessions</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{stats.work_sets}</div>
      <div class="stat-label">Work Sets</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{stats.total_reps}</div>
      <div class="stat-label">Total Reps</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{fmtVol(stats.total_volume)}</div>
      <div class="stat-label">Total Volume (lb)</div>
    </div>
  </div>

  <section class="section">
    <div class="section-header"><h2>Volume Over Time</h2></div>
    <div class="card">
      <table>
        <thead><tr><th>Week</th><th>Sessions</th><th>Sets</th><th>Reps</th><th>Volume</th></tr></thead>
        <tbody>
          {weeklyVolume.map(w => (
            <tr>
              <td class="num">{w.week}</td>
              <td class="num">{w.workout_count}</td>
              <td class="num">{w.total_sets}</td>
              <td class="num">{w.total_reps}</td>
              <td><span class="weight">{fmtVol(w.total_volume)}</span><span class="weight-unit">lb</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="section">
    <div class="section-header"><h2>Intensity Distribution</h2></div>
    <div class="card">
      {intentDist.map(i => (
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
          <span class={`badge badge-${i.intent}`} style="min-width: 5rem; text-align: center;">{i.intent}</span>
          <div style="flex: 1; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden;">
            <div style={`width: ${pct(i.count, totalIntentSets)}%; height: 100%; border-radius: 4px; background: var(--accent);`}></div>
          </div>
          <span class="num" style="min-width: 2.5rem; text-align: right; font-size: 0.75rem;">{i.count} sets</span>
          <span style="color: var(--text-muted); font-size: 0.7rem; min-width: 2.5rem;">{pct(i.count, totalIntentSets)}%</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header"><h2>Volume by Exercise</h2></div>
    <div class="card">
      <table>
        <thead><tr><th>Exercise</th><th>Sets</th><th>Volume (lb)</th><th>% of Total</th></tr></thead>
        <tbody>
          {volumeByExercise.map(e => (
            <tr>
              <td><a href={`/exercise/${slugify(e.exercise_name)}`} style="color: var(--text); text-decoration: none; border-bottom: 1px solid var(--border-strong);">{e.exercise_name}</a></td>
              <td class="num">{e.sets}</td>
              <td><span class="weight">{fmtVol(e.volume)}</span></td>
              <td class="num" style="color: var(--text-secondary);">{pct(e.volume, stats.total_volume)}%</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
